use flake

# Project-local postgres cluster (managed via `just db-up`).
# Override PGSOCKET if you'd rather connect to a system-wide postgres.
: "${PGSOCKET:=$PWD/.pgdata}"

branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "main")
if [ "$branch" = "main" ]; then
  export DATABASE_URL="postgres:///djv?host=$PGSOCKET"
  echo "Database: djv (main branch)"
else
  export DATABASE_URL="postgres:///djv_dev?host=$PGSOCKET"
  echo "Database: djv_dev (branch: $branch)"
fi

# Sync configuration
DJV_USER="djvcom"
export DJV_GITHUB_USER="$DJV_USER"
export DJV_CRATES_IO_USER="$DJV_USER"
export DJV_CONTRIBUTIONS_USER="$DJV_USER"
export DJV_NPM_USER="djverrall"
export DJV_GITLAB_USER="djverrall"
